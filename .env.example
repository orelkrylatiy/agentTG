# Application Environment
APP_ENV=dev
LOG_LEVEL=INFO

# Telegram API Credentials (get from my.telegram.org)
TG_API_ID=123456
TG_API_HASH=replace_me
TG_PHONE=+10000000000

# Telethon Session File
TELETHON_SESSION_NAME=data/userbot.session

# Control Bot Token (from BotFather)
CONTROL_BOT_TOKEN=replace_me

# Owner Telegram ID (your numeric Telegram ID, use @userinfobot to find)
OWNER_TELEGRAM_ID=123456789

# Database Configuration
DATABASE_URL=sqlite:///./data/agent.db

# Agent Global State
AGENT_GLOBAL_ENABLED=false
DEFAULT_CHAT_MODE=DRAFT

# LLM Provider Configuration
# Options: chatgpt_oauth, openai, openrouter
LLM_PROVIDER=chatgpt_oauth
LLM_MODEL=chatgpt/gpt-5

# LiteLLM ChatGPT OAuth (uses your ChatGPT Plus subscription)
LITELLM_CHATGPT_ENABLED=true
CHATGPT_TOKEN_DIR=data/litellm/chatgpt
CHATGPT_AUTH_FILE=auth.json
CHATGPT_API_BASE=https://chatgpt.com/backend-api/codex
CHATGPT_ORIGINATOR=codex_cli_rs

# OpenAI Fallback (optional)
OPENAI_API_KEY=
OPENAI_FALLBACK_MODEL=gpt-4o-mini

# OpenRouter Fallback (optional)
OPENROUTER_API_KEY=
OPENROUTER_FALLBACK_MODEL=openrouter/openai/gpt-4o-mini

# Rate Limiting
COOLDOWN_SECONDS=120

# Owner Takeover - pause agent after owner activity
OWNER_TAKEOVER_PAUSE_MINUTES=30

# Context and Reply Limits
MAX_CONTEXT_MESSAGES=12
MAX_REPLY_CHARS=800

# Safety Settings
REQUIRE_APPROVAL_FOR_UNKNOWN_CHATS=true
REQUIRE_APPROVAL_FOR_INITIATIVE_MESSAGES=true
REQUIRE_APPROVAL_FOR_MONEY_OR_COMMITMENTS=true
